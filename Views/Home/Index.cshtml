@{
    ViewData["Title"] = "Home";
}

<style>
  /* ── HERO ── */
  .hero {
    display: grid; grid-template-columns: 1fr 1fr; gap: 40px;
    align-items: center; padding: 80px 60px 60px; max-width: 1300px; margin: 0 auto;
  }
  .hero-text h1 { font-size: 3.6rem; line-height: 1.08; margin-bottom: 20px; }
  .hero-text h1 em { font-style: italic; color: var(--green-btn); }
  .hero-text p { color: var(--muted); line-height: 1.7; max-width: 420px; margin-bottom: 32px; }
  .hero-ctas { display: flex; gap: 14px; flex-wrap: wrap; }
  .btn-primary { background: var(--dark); color: #fff; border: none; padding: 14px 32px; border-radius: 50px; font-family: 'DM Sans', sans-serif; font-size: 1rem; font-weight: 600; cursor: pointer; text-decoration: none; }
  .btn-secondary { background: none; border: 2px solid var(--dark); padding: 14px 28px; border-radius: 50px; font-family: 'DM Sans', sans-serif; font-size: 1rem; font-weight: 600; cursor: pointer; display: flex; align-items: center; gap: 8px; }
  .hero-stats { display: flex; gap: 28px; margin-top: 40px; }
  .hero-stat strong { font-size: 1.5rem; font-family: 'Fraunces', serif; }
  .hero-stat span { display: block; font-size: .8rem; color: var(--muted); }
  .hero-img { position: relative; }
  .hero-img img { width: 100%; border-radius: var(--radius); object-fit: cover; max-height: 480px; }
  .hero-badge {
    position: absolute; bottom: -20px; left: -20px;
    background: #fff; border-radius: 16px; padding: 14px 20px;
    box-shadow: 0 8px 30px rgba(0,0,0,.1); display: flex; align-items: center; gap: 12px;
  }
  .hero-badge-icon { background: var(--sage); width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.2rem; }
  .hero-badge small { font-size: .75rem; color: var(--muted); }
  .hero-badge strong { display: block; font-size: .95rem; }

  /* ── LOGOS ── */
  .logos { padding: 40px 60px; border-top: 1px solid #e8ddd4; border-bottom: 1px solid #e8ddd4; }
  .logos-inner { display: flex; justify-content: space-around; align-items: center; max-width: 1100px; margin: 0 auto; flex-wrap: wrap; gap: 20px; }
  .logo-item { display: flex; align-items: center; gap: 10px; color: #9a9a8a; font-weight: 600; font-size: 1rem; }
  .logo-icon { width: 32px; height: 32px; background: #d8d4c8; border-radius: 6px; display: flex; align-items: center; justify-content: center; font-size: .9rem; }

  /* ── CATEGORIES ── */
  .categories { padding: 80px 60px; max-width: 1300px; margin: 0 auto; }
  .section-header { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 40px; }
  .section-header h2 { font-size: 2.4rem; max-width: 280px; line-height: 1.15; }
  .cat-cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
  .cat-card {
    border-radius: var(--radius); padding: 32px; min-height: 220px;
    display: flex; flex-direction: column; justify-content: space-between; cursor: pointer;
    transition: transform .2s;
  }
  .cat-card:hover { transform: translateY(-4px); }
  .cat-card.peach { background: #f5d9c0; }
  .cat-card.yellow { background: var(--yellow); }
  .cat-card.sage { background: var(--sage); }
  .cat-icon { width: 54px; height: 54px; background: rgba(255,255,255,.5); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.4rem; margin-bottom: 24px; }
  .cat-card h3 { font-size: 1rem; font-family: 'DM Sans', sans-serif; font-weight: 600; }
  .nav-arrows { display: flex; gap: 10px; margin-top: 32px; }
  .arrow-btn { width: 44px; height: 44px; border-radius: 50%; border: 2px solid var(--dark); background: none; cursor: pointer; font-size: 1rem; display: flex; align-items: center; justify-content: center; transition: all .2s; }
  .arrow-btn:hover { background: var(--dark); color: #fff; }

  /* ── VIDEO ── */
  .video-section { text-align: center; padding: 80px 60px 0; }
  .video-section h2 { font-size: 2.6rem; margin-bottom: 10px; }
  .video-section p { color: var(--muted); margin-bottom: 40px; }
  .video-wrap { position: relative; max-width: 860px; margin: 0 auto; border-radius: var(--radius); overflow: hidden; }
  .video-placeholder {
    width: 100%; height: 420px; background: linear-gradient(135deg, #d8c8b8, #c8b8a8);
    display: flex; align-items: center; justify-content: center; cursor: pointer;
  }
  .play-btn {
    width: 60px; height: 60px; background: rgba(255,255,255,.85); border-radius: 50%;
    display: flex; align-items: center; justify-content: center; font-size: 1.2rem;
    box-shadow: 0 4px 20px rgba(0,0,0,.15); cursor: pointer; transition: transform .2s;
  }
  .play-btn:hover { transform: scale(1.1); }
  .video-decor { position: absolute; top: 20px; right: -30px; display: flex; flex-direction: column; gap: 8px; opacity: .5; }
  .dot { width: 8px; height: 8px; background: var(--dark); border-radius: 50%; }

  /* ── STATS ── */
  .stats-bar {
    background: var(--sage); border-radius: var(--radius);
    max-width: 860px; margin: 0 auto; padding: 40px 50px;
    display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 20px; align-items: center;
    transform: translateY(-40px);
  }
  .stats-bar .stat-big { font-size: 2.6rem; font-family: 'Fraunces', serif; font-weight: 900; text-decoration: underline; }
  .stats-bar .stars { color: #e84545; font-size: 1rem; margin: 4px 0; }
  .stats-bar .stars.gold { color: #f0a500; }
  .stats-bar small { color: var(--muted); font-size: .85rem; }
  .join-btn { background: var(--green-btn); color: #fff; border: none; padding: 12px 26px; border-radius: 50px; font-family: 'DM Sans', sans-serif; font-weight: 600; cursor: pointer; }
  .testimonial-chip { background: #fff; border-radius: 50px; padding: 8px 16px; display: flex; align-items: center; gap: 8px; font-size: .85rem; margin-top: 10px; }
  .chip-avatar { width: 28px; height: 28px; border-radius: 50%; background: var(--sage); }

  /* ── COURSES ── */
  .courses { padding: 60px 60px 80px; max-width: 1300px; margin: 0 auto; }
  .courses .section-header h2 { font-size: 2.2rem; max-width: none; }
  .course-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 28px; margin-top: 30px; }
  .course-card { background: #fff; border-radius: var(--radius); overflow: hidden; transition: box-shadow .2s; border: 1px solid #ede5da; }
  .course-card:hover { box-shadow: 0 12px 40px rgba(0,0,0,.1); }
  .course-thumb { height: 180px; display: flex; align-items: center; justify-content: center; position: relative; font-size: 3rem; }
  .course-thumb.green { background: #c5d9c8; }
  .course-thumb.orange { background: #f5c878; }
  .course-thumb.pink { background: #f5b8b8; }
  .course-thumb.purple { background: #c8c0e8; }
  .course-thumb.blue { background: #b8d0f0; }
  .course-thumb.rose { background: #f8c0cc; }
  .instructor-badge {
    position: absolute; top: 12px; right: 12px;
    background: #fff; border-radius: 50px; padding: 4px 12px 4px 6px;
    display: flex; align-items: center; gap: 6px; font-size: .8rem; font-weight: 600;
    box-shadow: 0 2px 8px rgba(0,0,0,.1);
  }
  .instr-avatar { width: 26px; height: 26px; border-radius: 50%; background: var(--sage); }
  .course-body { padding: 18px; }
  .course-body h3 { font-size: 1rem; font-family: 'DM Sans', sans-serif; font-weight: 700; margin-bottom: 8px; line-height: 1.3; }
  .course-meta { display: flex; gap: 14px; font-size: .78rem; color: var(--muted); margin-bottom: 12px; flex-wrap: wrap; }
  .course-price { font-size: .95rem; font-weight: 700; color: var(--green-btn); }
  .course-price s { color: var(--muted); font-weight: 400; margin-left: 6px; font-size: .85rem; }

  /* ── TESTIMONIALS ── */
  .testimonials { background: #fde8d8; padding: 80px 60px; text-align: center; position: relative; }
  .testimonials h2 { font-size: 2.6rem; margin-bottom: 10px; }
  .testimonials .sub { color: var(--muted); margin-bottom: 50px; }
  .floating-avatars { position: relative; }
  .fa { position: absolute; width: 60px; height: 60px; border-radius: 50%; background: var(--sage); display: flex; align-items: center; justify-content: center; font-size: 1.5rem; }
  .fa.tl { top: -30px; left: 15%; }
  .fa.tr { top: -30px; right: 15%; }
  .fa.ml { top: 20px; left: 6%; }
  .fa.mr { top: 20px; right: 6%; }
  .review-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; max-width: 1200px; margin: 0 auto; text-align: left; }
  .review-card { background: #fff; border-radius: 16px; padding: 24px; }
  .stars-row { color: #f0a500; font-size: .9rem; margin-bottom: 12px; }
  .review-card p { font-size: .88rem; color: var(--muted); line-height: 1.6; margin-bottom: 18px; }
  .reviewer { display: flex; align-items: center; gap: 10px; }
  .rev-avatar { width: 40px; height: 40px; border-radius: 50%; background: var(--sage); display: flex; align-items: center; justify-content: center; font-size: .8rem; overflow: hidden; }
  .rev-name { font-weight: 700; font-size: .9rem; }
  .rev-role { font-size: .78rem; color: var(--green-btn); }

  /* ── HOW IT WORKS ── */
  .how { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; padding: 80px 60px; max-width: 1300px; margin: 0 auto; align-items: center; }
  .how-left { position: relative; }
  .how-photo { width: 100%; border-radius: 50% 50% 50% 50% / 40% 40% 60% 60%; object-fit: cover; height: 460px; background: linear-gradient(135deg, #d8c8b8, #c8b8a8); display: flex; align-items: center; justify-content: center; font-size: 5rem; }
  .congrats-card {
    position: absolute; top: 20px; right: -20px;
    background: #fff; border-radius: 14px; padding: 14px 18px;
    box-shadow: 0 8px 30px rgba(0,0,0,.12); text-align: center; min-width: 180px;
  }
  .check-icon { background: #4caf50; color: #fff; border-radius: 50%; width: 32px; height: 32px; display: flex; align-items: center; justify-content: center; margin: 0 auto 6px; font-size: .9rem; }
  .congrats-card strong { font-size: .95rem; display: block; margin-bottom: 4px; }
  .congrats-card small { color: var(--muted); font-size: .78rem; }
  .edulink-card {
    position: absolute; bottom: 20px; right: -20px;
    background: #fff; border-radius: 14px; padding: 16px 20px;
    box-shadow: 0 8px 30px rgba(0,0,0,.12); min-width: 200px;
  }
  .edulink-card .brand { font-family: 'Fraunces', serif; font-size: 1rem; font-weight: 900; margin-bottom: 4px; }
  .edulink-card .brand span { color: var(--green-btn); }
  .edulink-card .tagline { font-size: .8rem; color: var(--green-btn); margin-bottom: 8px; }
  .edulink-card p { font-size: .75rem; color: var(--muted); margin-bottom: 12px; line-height: 1.5; }
  .edulink-card button { background: var(--dark); color: #fff; border: none; padding: 8px 20px; border-radius: 50px; font-family: 'DM Sans', sans-serif; font-size: .82rem; font-weight: 600; cursor: pointer; width: 100%; }
  .how-steps { display: flex; flex-direction: column; gap: 20px; }
  .how-steps h2 { font-size: 2.4rem; line-height: 1.15; margin-bottom: 28px; }
  .step-card { border-radius: 16px; padding: 22px 26px; display: flex; align-items: flex-start; gap: 18px; }
  .step-card.lav { background: var(--lavender); }
  .step-card.sage { background: var(--sage); }
  .step-card.yel { background: var(--yellow); }
  .step-num { width: 42px; height: 42px; border-radius: 50%; background: rgba(255,255,255,.6); display: flex; align-items: center; justify-content: center; font-size: 1.1rem; flex-shrink: 0; }
  .step-card h3 { font-size: 1rem; font-family: 'DM Sans', sans-serif; font-weight: 700; margin-bottom: 4px; }
  .step-card p { font-size: .85rem; color: var(--muted); line-height: 1.5; }

  /* ── BLOG ── */
  .blog { padding: 60px 60px 80px; max-width: 1300px; margin: 0 auto; }
  .blog .section-header h2 { font-size: 2.2rem; max-width: none; }
  .blog-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 28px; margin-top: 30px; }
  .blog-card { border-radius: var(--radius); overflow: hidden; background: var(--cream); border: 1px solid #ede5da; transition: box-shadow .2s; }
  .blog-card:hover { box-shadow: 0 12px 40px rgba(0,0,0,.1); }
  .blog-thumb { height: 200px; background: #d8c8b8; display: flex; align-items: center; justify-content: center; font-size: 3.5rem; position: relative; }
  .blog-thumb img { width: 100%; height: 100%; object-fit: cover; }
  .blog-meta { background: #fff; border-radius: 16px; position: absolute; bottom: 10px; left: 10px; padding: 10px 14px; font-size: .8rem; }
  .blog-tag { display: inline-block; background: var(--dark); color: #fff; border-radius: 50px; padding: 2px 10px; font-size: .72rem; font-weight: 600; margin-right: 8px; }
  .blog-date { color: var(--muted); }
  .blog-card h3 { font-family: 'DM Sans', sans-serif; font-size: .95rem; font-weight: 700; padding: 14px 16px 18px; line-height: 1.4; }

  @@media (max-width: 900px) {
    .nav-links { display: none; }
    .hero, .how { grid-template-columns: 1fr; padding: 40px 20px; }
    .categories, .courses, .blog, .testimonials, .stats-bar, .logos, .video-section { padding: 40px 20px; }
    .cat-cards, .course-grid, .review-grid, .blog-grid { grid-template-columns: 1fr; }
    .hero-text h1 { font-size: 2.4rem; }
  }
</style>

