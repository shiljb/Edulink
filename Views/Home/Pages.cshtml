@{
    ViewData["Title"] = "Pages";
}

<div class="max-w-7xl mx-auto px-6 py-12">
    <section class="pt-12 pb-24 text-center relative overflow-hidden">
        <div class="max-w-xl mx-auto mb-10">
            <h2 class="text-3xl font-extrabold text-black mb-4 font-body">
                Watch our demo video
            </h2>
            <p class="text-black text-sm leading-relaxed px-4">
                Which is the same as saying through shrinking from toil and pain. These cases are perfectly simple and
                easy to distinguish.
            </p>
        </div>
        <div class="relative max-w-md mx-auto z-10">
            <div class="absolute -right-4 -top-6 w-12 h-12 pointer-events-none opacity-60">
                <svg class="w-full h-full fill-gray-800 dark:fill-gray-200" viewBox="0 0 100 100">
                    <circle cx="20" cy="20" r="5"></circle>
                    <circle cx="50" cy="15" r="5"></circle>
                    <circle cx="80" cy="25" r="5"></circle>
                    <circle cx="35" cy="45" r="5"></circle>
                    <circle cx="65" cy="55" r="5"></circle>
                    <circle cx="90" cy="65" r="5"></circle>
                </svg>
            </div>
            <div class="rounded-3xl overflow-hidden shadow-2xl border-4 border-white dark:border-gray-800 relative group aspect-video">
                <iframe width="100%" height="100%" src="https://www.youtube.com/embed/d-8egPSczWc" title="EduLink Demo Video" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen class="absolute inset-0 w-full h-full"></iframe>
            </div>
        </div>
    </section>

    <section class="bg-sage-muted  dark:bg-sage-dark pt-32 pb-16 px-6 -mt-20 relative rounded-[3rem]">
        <div class="max-w-md mx-auto space-y-12">
            <div class="space-y-6">
                <h1 class="text-3xl max-w-7xl font-extrabold text-black leading-tight font-body">
                    Trusted by the 20,000+ happy students and online users sins 2024
                </h1>
                <a asp-controller="Home" asp-action="signup" class="inline-block bg-[#1a1a14] hover:bg-black text-white font-semibold py-3 px-8 rounded-xl transition-colors shadow-md text-sm text-center">
                    Join our community
                </a>
            </div>
            <div class="grid grid-cols-2 gap-8 items-start">
                <div>
                    <div class="text-5xl font-extrabold text-black border-b-4 border-black/10 pb-2 inline-block">
                        10K
                    </div>
                    <p class="text-[10px] text-black uppercase tracking-wider font-semibold mt-4">
                        world wide students love us
                    </p>
                </div>
                <div>
                    <div class="text-5xl font-extrabold text-black border-b-4 border-black/10 pb-2 inline-block">
                        4.7
                    </div>
                    <p class="text-[10px] text-black uppercase tracking-wider font-semibold mt-4">
                        1456 user review by Google
                    </p>
                </div>
            </div>
        </div>
    </section>
</div>
