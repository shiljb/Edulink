<style data-purpose="custom-styling">
    /* Subtle organic curves and smooth transitions */
    .form-container {
      border-radius: 1.5rem;
    }
    input, textarea {
      border: 1px solid rgba(0, 0, 0, 0.05) !important;
      background-color: rgba(255, 255, 255, 0.3) !important;
    }
    input:focus, textarea:focus {
      outline: none !important;
      ring: 2px !important;
      ring-color: #8EAF96 !important;
      border-color: #8EAF96 !important;
    }
    /* Decorative squiggle imitation */
    .squiggle-deco {
      position: absolute;
      top: 2rem;
      left: 1.5rem;
      width: 60px;
      height: 60px;
      opacity: 0.6;
    }
  </style>

<!-- BEGIN: MainContent -->
<main class="relative px-6 py-12 flex flex-col items-center bg-[#FAF5EE]">
<!-- BEGIN: DecorativeElement -->
<!-- Mimicking the pink squiggle from the reference image -->
<div class="squiggle-deco pointer-events-none" data-purpose="decorative-illustration">
<svg fill="none" viewbox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
<path d="M10 50C20 20 40 20 50 50C60 80 80 80 90 50" fill="none" stroke="#F9A8D4" stroke-linecap="round" stroke-width="4"></path>
<path d="M15 60C25 30 45 30 55 60C65 90 85 90 95 60" fill="none" opacity="0.5" stroke="#F9A8D4" stroke-linecap="round" stroke-width="4"></path>
</svg>
</div>
<!-- END: DecorativeElement -->
<!-- BEGIN: HeaderSection -->
<section class="text-center mb-10 mt-8" data-purpose="page-header">
<h1 class="text-4xl font-bold tracking-tight mb-4 text-gray-900">
        We're here to help!
      </h1>
<p class="text-gray-600 max-w-xs mx-auto text-sm leading-relaxed">
        Earth Creepeth Fish earth great saying also itself. Reach out and we'll get back to you shortly.
      </p>
</section>
<!-- END: HeaderSection -->
<!-- BEGIN: ContactFormCard -->
<section class="w-full max-w-md bg-[#C8DCD0] p-8 shadow-sm form-container" data-purpose="contact-form-container">
<h2 class="text-2xl font-bold text-gray-800 mb-8">Let's chat</h2>
<form action="#" class="space-y-4" method="POST">
<!-- Name Field -->
<div>
<label class="sr-only" for="full-name">Your Name</label>
<input class="block w-full rounded-lg px-4 py-3 text-sm text-gray-700 placeholder-gray-500 transition-colors" id="full-name" name="full-name" placeholder="Your Name" type="text"/>
</div>
<!-- Email Field -->
<div class="relative">
<label class="sr-only" for="email">Your Email</label>
<input class="block w-full rounded-lg px-4 py-3 text-sm text-gray-700 placeholder-gray-500 transition-colors" id="email" name="email" placeholder="Your Email" type="email"/>
<!-- Email Icon simulation -->
<div class="absolute inset-y-0 right-0 pr-3 flex items-center pointer-events-none">
<svg class="h-5 w-5 text-gray-400" fill="currentColor" viewbox="0 0 20 20">
<path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"></path>
<path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"></path>
</svg>
</div>
</div>
<!-- Phone Field -->
<div>
<label class="sr-only" for="phone">Your Phone no.</label>
<input class="block w-full rounded-lg px-4 py-3 text-sm text-gray-700 placeholder-gray-500 transition-colors" id="phone" name="phone" placeholder="Your Phone no." type="tel"/>
</div>
<!-- Subject Field -->
<div>
<label class="sr-only" for="subject">Your Subject</label>
<input class="block w-full rounded-lg px-4 py-3 text-sm text-gray-700 placeholder-gray-500 transition-colors" id="subject" name="subject" placeholder="Your Subject" type="text"/>
</div>
<!-- Message Field -->
<div>
<label class="sr-only" for="message">Your Message</label>
<textarea class="block w-full rounded-lg px-4 py-3 text-sm text-gray-700 placeholder-gray-500 transition-colors resize-none" id="message" name="message" placeholder="Your Message" rows="4"></textarea>
</div>
<!-- Submit Button -->
<div class="pt-4">
<button class="w-full bg-[#8EAF96] hover:bg-opacity-90 text-white font-medium py-4 px-6 rounded-lg shadow-sm transition-all active:scale-[0.98]" type="submit">
            Send Message
          </button>
</div>
</form>
</section>
<!-- END: ContactFormCard -->
<!-- BEGIN: ContextImage -->
<!-- Mobile optimized context image placement -->
<section class="w-full max-w-md mt-12 mb-8" data-purpose="brand-imagery">
<div class="rounded-2xl overflow-hidden shadow-lg border-b-4 border-gray-900/10">
