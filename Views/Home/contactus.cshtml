@{
    ViewData["Title"] = "Contact Us";
}

<style>
  /* ---- HEADER ---- */
  .hero-contact {
    text-align: center;
    padding: 60px 24px 48px;
    position: relative;
  }

  .hero-contact h1 {
    font-family: 'Fraunces', serif;
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 900;
    letter-spacing: -0.5px;
    margin-bottom: 12px;
    color: #1e1e1e;
  }

  .hero-contact p {
    font-size: 0.9rem;
    color: #888;
  }

  /* ---- MAIN SECTION ---- */
  .main-wrap {
    max-width: 1180px;
    margin: 0 auto;
    padding: 0 40px 60px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 36px;
    align-items: start;
  }

  @@media (max-width: 820px) {
    .main-wrap { grid-template-columns: 1fr; padding: 0 20px 48px; }
  }

  /* ---- FORM CARD ---- */
  .form-card {
    background: #b8d4b8;
    border-radius: 20px;
    padding: 36px 32px 32px;
  }

  .form-card h2 {
    font-family: 'Fraunces', serif;
    font-size: 1.7rem;
    font-weight: 700;
    margin-bottom: 24px;
    color: #1e1e1e;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
    margin-bottom: 14px;
  }

  .form-row.single { grid-template-columns: 1fr; }

  .contact-input, .contact-textarea {
    width: 100%;
    background: #fff;
    border: 1.5px solid transparent;
    border-radius: 10px;
    padding: 13px 16px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.88rem;
    color: #333;
    outline: none;
    transition: border-color .2s;
  }

  .contact-input:focus, .contact-textarea:focus { border-color: #7ab07a; }

  .btn-send {
    width: 100%;
    margin-top: 16px;
    background: #7ab07a;
    color: #fff;
    border: none;
    border-radius: 10px;
    padding: 15px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.95rem;
    font-weight: 600;
    cursor: pointer;
    transition: background .2s, transform .15s;
    color: #fff !important;
  }

  .btn-send:hover { background: #669966; transform: translateY(-1px); }

  /* ---- IMAGE ---- */
  .hero-img-contact {
    border-radius: 20px;
    overflow: hidden;
    height: 100%;
    min-height: 380px;
    background: #c8c0b8;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 5rem;
  }

  /* ---- INFO CARDS ---- */
  .info-section {
    max-width: 1180px;
    margin: 0 auto;
    padding: 0 40px 60px;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  @@media (max-width: 820px) {
    .info-section { grid-template-columns: 1fr; padding: 0 20px 48px; }
  }

  .info-card {
    background: #dde0f5;
    border-radius: 18px;
    padding: 36px 24px;
    text-align: center;
  }

  .info-card h3 {
    font-family: 'DM Sans', sans-serif;
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 8px;
    color: #1e1e1e;
  }

  .info-card a, .info-card p {
    font-size: 0.88rem;
    color: #555;
  }
</style>

<!-- HEADER -->
<div class="hero-contact">
  <h1>We're here to help!</h1>
  <p>Earth Creepeth Fish earth great saying also itself.</p>
</div>

<!-- MAIN CONTENT -->
<div class="main-wrap">

  <!-- FORM -->
  <div class="form-card">
    <h2>Let's chat</h2>

    <div class="form-row">
      <input type="text" class="contact-input" placeholder="Your Name">
      <input type="email" class="contact-input" placeholder="Your Email">
    </div>

    <div class="form-row">
      <input type="tel" class="contact-input" placeholder="Your Phone no.">
      <input type="text" class="contact-input" placeholder="Your Subject">
    </div>

    <div class="form-row single">
      <textarea class="contact-textarea" placeholder="Your Message" rows="5"></textarea>
    </div>

    <button class="btn-send">Send Message</button>
  </div>

  <!-- IMAGE -->
  <div class="hero-img-contact">
    👩‍🏫
  </div>

</div>

<!-- INFO CARDS -->
<div class="info-section">
  <div class="info-card">
    <h3>Call us:</h3>
    <a href="tel:+015982694756">+01 598 269 4756</a>
  </div>

  <div class="info-card">
    <h3>Email us:</h3>
    <a href="mailto:info@example.com">info@example.com</a>
  </div>

  <div class="info-card">
    <h3>Address:</h3>
    <p>Chicago HQ Estica Cop. Macomb, MI 48042</p>
  </div>
</div>