@{
    ViewData["Title"] = "Log In";
}

<style>
    .login-wrapper {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 80px 20px;
    }
    .login-card {
        background: #fff;
        border-radius: 20px;
        padding: 40px;
        box-shadow: 10px 10px 0px 0px rgba(0, 0, 0, 0.8);
        border: 1px solid #eee;
        max-width: 450px;
        width: 100%;
    }
    .login-card h1 {
        font-size: 2.5rem;
        margin-bottom: 8px;
        text-align: center;
    }
    .login-card p {
        color: #666;
        text-align: center;
        margin-bottom: 32px;
    }
</style>

<div class="login-wrapper">
    <div class="login-card">
        <h1>Log in</h1>
        <p>Please fill your email and password to login</p>

        @if (ViewBag.ErrorMessage != null)
        {
            <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative mb-4" role="alert">
                <span class="block sm:inline">@ViewBag.ErrorMessage</span>
            </div>
        }

        <form asp-controller="Home" asp-action="login" class="space-y-6" method="POST">
            <div>
                <label class="block text-sm font-medium mb-2">Email</label>
                <input class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-green-500 focus:border-green-500 transition-colors" name="email" placeholder="Email address" required type="email"/>
            </div>
            
            <div>
                <div class="flex justify-between items-center mb-2">
                    <label class="block text-sm font-medium">Password</label>
                    <a class="text-xs text-gray-500 hover:underline" href="#">Forgot password?</a>
                </div>
                <input class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-green-500 focus:border-green-500 transition-colors" name="password" placeholder="Password" required type="password"/>
            </div>
            
            <div class="pt-4">
                <button class="w-full bg-slate-900 hover:bg-slate-800 text-white font-medium py-3.5 rounded-xl transition-all shadow-sm active:scale-[0.98]" type="submit">
                    Log In
                </button>
            </div>
        </form>

        <div class="mt-8 text-center">
            <p class="text-sm">
                Don't have an account? 
                <a class="font-semibold underline underline-offset-4 hover:text-gray-700" asp-controller="Home" asp-action="signup">Sign up</a>
            </p>
        </div>
    </div>
</div>