@{
    ViewData["Title"] = "Courses";
}

<style>
  :root {
    --bg: #f5f0e8;
    --text: #1a1a1a;
    --muted: #888;
    --green: #2d6a4f;
    --price: #1a1a1a;
    --old-price: #aaa;
    --card-radius: 16px;
    --shadow: 0 4px 24px rgba(0,0,0,0.08);
  }

  /* ---- header ---- */
  .courses-header {
    text-align: center;
    padding: 64px 24px 40px;
    position: relative;
  }
  .courses-header h1 {
    font-family: 'Fraunces', serif;
    font-size: clamp(2.2rem, 5vw, 3.4rem);
    font-weight: 900;
    letter-spacing: -1px;
    line-height: 1.1;
    margin-bottom: 12px;
  }
  .courses-header p {
    color: var(--muted);
    font-size: 0.95rem;
  }

  /* decorative x marks */
  .deco {
    position: absolute;
    top: 30px; left: 60px;
    pointer-events: none;
    user-select: none;
  }
  .deco span {
    display: block;
    font-size: 1.1rem;
    color: #aaa;
    line-height: 1.6;
    letter-spacing: 10px;
  }

  /* ---- grid ---- */
  .section { display: none; }
  .section.active { display: block; }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
    max-width: 1160px;
    margin: 0 auto;
    padding: 0 40px 40px;
  }

  @@media (max-width: 900px) { .grid { grid-template-columns: repeat(2,1fr); } }
  @@media (max-width: 580px) { .grid { grid-template-columns: 1fr; padding: 0 16px 32px; } }

  /* ---- card ---- */
  .card {
    background: #fff;
    border-radius: var(--card-radius);
    overflow: hidden;
    box-shadow: var(--shadow);
    transition: transform .25s ease, box-shadow .25s ease;
    cursor: pointer;
  }
  .card:hover {
    transform: translateY(-5px);
    box-shadow: 0 12px 40px rgba(0,0,0,0.13);
  }

  .card-thumb {
    position: relative;
    height: 190px;
    overflow: hidden;
  }
  .card-thumb img {
    width: 100%; height: 100%; object-fit: cover;
  }

  /* colored bg placeholders */
  .card-thumb .thumb-bg {
    width: 100%; height: 100%;
    display: flex; align-items: center; justify-content: center;
    font-size: 3.5rem;
    font-weight: 900;
  }

  .instructor {
    position: absolute;
    top: 14px; right: 14px;
    background: #fff;
    border-radius: 30px;
    padding: 5px 12px 5px 5px;
    display: flex; align-items: center; gap: 7px;
    font-size: 0.78rem;
    font-weight: 600;
    box-shadow: 0 2px 8px rgba(0,0,0,0.12);
  }
  .instructor-avatar {
    width: 26px; height: 26px;
    border-radius: 50%;
    object-fit: cover;
    background: #ddd;
    display: flex; align-items: center; justify-content: center;
    font-size: 0.65rem;
    font-weight: 700;
    color: #555;
    overflow: hidden;
  }

  .card-body { padding: 18px 20px 20px; }
  .card-body h3 {
    font-family: 'DM Sans', sans-serif;
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.35;
    margin-bottom: 10px;
  }

  .meta {
    display: flex; gap: 14px;
    font-size: 0.75rem;
    color: var(--muted);
    margin-bottom: 14px;
    flex-wrap: wrap;
  }
  .meta span { display: flex; align-items: center; gap: 4px; }

  .price { display: flex; align-items: center; gap: 10px; }
  .price .now {
    font-weight: 700;
    color: var(--green);
  }
  .price .was {
    font-size: 0.82rem;
    color: var(--old-price);
    text-decoration: line-through;
  }

  /* ---- pagination ---- */
  .pagination {
    max-width: 1160px;
    margin: 0 auto;
    padding: 8px 40px 60px;
    display: flex;
    align-items: center;
    gap: 20px;
  }
  @@media(max-width:580px){.pagination{padding:8px 16px 48px;}}

  .page-info {
    font-size: 0.88rem;
    color: var(--muted);
    font-weight: 500;
    margin-right: auto;
  }

  .btn-page {
    background: #1a1a1a;
    color: #fff;
    border: none;
    border-radius: 10px;
    padding: 13px 32px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    display: flex; align-items: center; gap: 6px;
    transition: background .2s;
  }
  .btn-page:hover { background: #333; }

  /* thumb color themes */
  .t-mint   { background: #c8f0d8; }
  .t-orange { background: #fde4b0; }
  .t-pink   { background: #fdd4d4; }
  .t-indigo { background: #d4d8f8; }
  .t-lavender{ background: #e6d4f8; }
  .t-yellow { background: #fde68a; }
  .t-blue   { background: #bfdbfe; }
  .t-teal   { background: #99f6e4; }
  .t-salmon { background: #fca5a5; }
  .t-peach  { background: #fdba74; }
  .t-slate  { background: #cbd5e1; }
  .t-rose   { background: #fecdd3; }
</style>

