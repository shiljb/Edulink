<!DOCTYPE html>
<html class="light" lang="en">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>@ViewData["Title"] - EduLink</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,typography"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@700&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons+Outlined" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@24,400,0,0" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" rel="stylesheet" />
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        primary: "#4B7E67",
                        "background-light": "#FDF8F1",
                        "background-dark": "#121212",
                        "accent-peach": "#FFE4D6",
                        "sage-muted": "#C1D3C1",
                        "sage-dark": "#2D3A2D",
                        "accent-pink": "#F8B4B4",
                        "footer-dark": "#1A1614",
                    },
                    fontFamily: {
                        sans: ["Inter", "sans-serif"],
                        display: ["Playfair Display", "serif"],
                        body: ["Plus Jakarta Sans", "sans-serif"],
                    },
                    borderRadius: {
                        DEFAULT: "12px",
                    },
                },
            },
        };
    </script>
    <style>
        body { font-family: 'Inter', sans-serif; }
        .font-display { font-family: 'Playfair Display', serif; }
        .font-body { font-family: 'Plus Jakarta Sans', sans-serif; }
        
        /* Custom Styles from index.html */
        .hero-image-clip { border-radius: 40px; }
        .pill-avatar-group {
            display: inline-flex;
            align-items: center;
            background: white;
            border: 1px solid #e5e7eb;
            padding: 4px 12px;
            border-radius: 9999px;
            margin: 0 8px;
        }
        .dark .pill-avatar-group { background: #222; border-color: #333; }
        .bg-green-accent { background-color: #E2EDE3; }
        .dark .bg-green-accent { background-color: #1a2e21; }
        
        .hide-scrollbar::-webkit-scrollbar { display: none; }
        .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
        
        .outline-text {
            -webkit-text-stroke: 1px currentColor;
            color: transparent;
        }

        @@keyframes scroll {
            0% { transform: translateX(0); }
            100% { transform: translateX(-50%); }
        }
        .animate-scroll {
            display: flex;
            animation: scroll 20s linear infinite;
        }
    </style>
</head>
<body class="bg-background-light dark:bg-background-dark text-gray-900 dark:text-gray-100 min-h-screen font-sans transition-colors duration-300">
    <header class="relative z-50">
        <nav class="max-w-7xl mx-auto px-6 py-6 flex items-center justify-between">
            <div class="flex items-center space-x-12">
                <a asp-controller="Home" asp-action="Index" class="flex items-center gap-2">
                    <div class="bg-primary text-white w-8 h-8 flex items-center justify-center font-bold text-xl rounded">E</div>
                    <span class="text-2xl font-bold tracking-tight text-gray-800 dark:text-white">duLink</span>
                </a>
                <div class="hidden md:flex items-center space-x-8 text-sm font-medium">
                    <a asp-controller="Home" asp-action="Index" class="hover:text-primary transition-colors">Home</a>
                    <a asp-controller="Home" asp-action="Courses" class="hover:text-primary transition-colors">Courses</a>
                    <a asp-controller="Home" asp-action="Pages" class="flex items-center gap-1 hover:text-primary transition-colors">
                        Pages <span class="material-icons-outlined text-sm">expand_more</span>
                    </a>
                    <a href="#" class="hover:text-primary transition-colors">Event</a>
                    <a href="#" class="hover:text-primary transition-colors">Contact Us</a>
                </div>
            </div>
            <div class="flex items-center space-x-6">
                <a class="text-sm font-semibold hover:opacity-80" href="#">Login</a>
                <a class="bg-gray-900 dark:bg-white dark:text-gray-900 text-white px-6 py-2.5 rounded-full text-sm font-semibold hover:opacity-90 transition-opacity" href="#">Sign up</a>
                <button onclick="document.documentElement.classList.toggle('dark')" class="p-2 rounded-full hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors">
                    <span class="material-icons-outlined block dark:hidden">dark_mode</span>
                    <span class="material-icons-outlined hidden dark:block">light_mode</span>
                </button>
            </div>
        </nav>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    <footer class="bg-footer-dark text-white rounded-t-[2.5rem] md:rounded-t-[4rem] px-8 py-16 md:px-16 mt-20">
        <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-12 gap-12">
            <div class="md:col-span-5 flex flex-col justify-between">
                <div>
                    <div class="flex items-center space-x-2 mb-12">
                        <div class="bg-primary w-10 h-10 rounded flex items-center justify-center text-white font-bold text-xl">E</div>
                        <span class="text-2xl font-semibold tracking-tight">duLink</span>
                    </div>
                    <div class="flex space-x-4 mb-12">
                        <a class="w-10 h-10 rounded-full bg-white flex items-center justify-center text-gray-900 hover:bg-primary hover:text-white transition-colors" href="#"><span class="material-icons text-xl">facebook</span></a>
                        <a class="w-10 h-10 rounded-full bg-white flex items-center justify-center text-gray-900 hover:bg-primary hover:text-white transition-colors" href="#"><span class="material-icons text-xl">camera_alt</span></a>
                        <a class="w-10 h-10 rounded-full bg-white flex items-center justify-center text-gray-900 hover:bg-primary hover:text-white transition-colors" href="#"><span class="material-icons text-xl">work</span></a>
                        <a class="w-10 h-10 rounded-full bg-white flex items-center justify-center text-gray-900 hover:bg-primary hover:text-white transition-colors" href="#"><span class="material-icons text-xl">close</span></a>
                    </div>
                </div>
                <div class="text-xs text-gray-400">
                    &copy; @DateTime.Now.Year EduLink. All rights reserved.
                </div>
            </div>
            <div class="md:col-span-7 grid grid-cols-2 md:grid-cols-3 gap-8">
                <div>
                    <h4 class="font-bold text-lg mb-6">Pages</h4>
                    <ul class="space-y-4 text-gray-400">
                        <li><a class="text-white hover:text-primary border-b border-primary pb-1" asp-action="Index">Home</a></li>
                        <li><a class="hover:text-white transition-colors" href="#">About</a></li>
                        <li><a class="hover:text-white transition-colors" href="#">FAQs</a></li>
                        <li><a class="hover:text-white transition-colors" href="#">Contact Us</a></li>
                    </ul>
                </div>
                <div>
                    <h4 class="font-bold text-lg mb-6">CMS page</h4>
                    <ul class="space-y-4 text-gray-400">
                        <li><a class="hover:text-white transition-colors" asp-action="Courses">Courses</a></li>
                        <li><a class="hover:text-white transition-colors" href="#">Blog</a></li>
                        <li><a class="hover:text-white transition-colors" href="#">Teacher</a></li>
                    </ul>
                </div>
                <div class="col-span-2 md:col-span-1">
                    <h4 class="font-bold text-lg mb-6">User page</h4>
                    <ul class="space-y-4 text-gray-400">
                        <li><a class="hover:text-white transition-colors" href="#">Style Guide</a></li>
                        <li><a class="hover:text-white transition-colors" href="#">Licenses</a></li>
                        <li><a class="hover:text-white transition-colors" href="#">Changelog</a></li>
                    </ul>
                </div>
            </div>
        </div>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
