<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EduLink</title>
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:wght@700;900&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com?plugins=forms,typography"></script>
    <style>
        :root {
            --cream: #f5ede4;
            --peach: #f5e0d0;
            --sage: #c5d9c8;
            --yellow: #f5f0a8;
            --lavender: #d6d4f0;
            --dark: #1a1a14;
            --muted: #6b6b5a;
            --green-btn: #7aab7e;
            --radius: 20px;
        }

        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--cream);
            color: var(--dark);
        }

        h1, h2, h3 {
            font-family: 'Fraunces', serif;
        }

        /* ── NAV ── */
        nav {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 18px 60px;
            background: var(--cream);
            position: sticky;
            top: 0;
            z-index: 100;
            border-bottom: 1px solid #e8ddd4;
        }

        .nav-logo {
            font-family: 'Fraunces', serif;
            font-size: 1.4rem;
            font-weight: 900;
            text-decoration: none;
            color: var(--dark);
        }

        .nav-logo span {
            color: var(--green-btn);
        }

        .nav-links {
            display: flex;
            gap: 32px;
            list-style: none;
        }

        .nav-links a {
            text-decoration: none;
            color: var(--dark);
            font-size: .95rem;
            font-weight: 500;
            transition: color 0.2s;
        }

        .nav-links a:hover {
            color: var(--green-btn);
        }

        .nav-actions {
            display: flex;
            gap: 12px;
            align-items: center;
        }

        .btn-nav-outline {
            border: 2px solid var(--dark);
            background: none;
            padding: 8px 20px;
            border-radius: 50px;
            font-family: 'DM Sans', sans-serif;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
            color: var(--dark);
            font-size: 0.9rem;
            display: inline-flex;
            align-items: center;
        }

        .btn-nav-dark {
            background: var(--dark);
            color: #fff;
            border: none;
            padding: 10px 22px;
            border-radius: 50px;
            font-family: 'DM Sans', sans-serif;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
            font-size: 0.9rem;
            display: inline-flex;
            align-items: center;
            color: #fff !important;
        }

        .btn-nav-dark:hover {
            opacity: .85;
            color: #fff !important;
        }

        /* ── FOOTER ── */
        footer {
            background: var(--dark);
            color: #fff;
            padding: 60px 60px 30px;
            margin-top: 80px;
        }

        .footer-top {
            display: grid;
            grid-template-columns: 2fr 1fr 1fr 1fr;
            gap: 40px;
            margin-bottom: 50px;
            max-width: 1300px;
            margin-left: auto;
            margin-right: auto;
        }

        .footer-brand .brand-name {
            font-family: 'Fraunces', serif;
            font-size: 1.4rem;
            font-weight: 900;
            margin-bottom: 12px;
        }

        .footer-brand .brand-name span {
            color: var(--sage);
        }

        .footer-brand p {
            color: #9a9a8a;
            font-size: .88rem;
            line-height: 1.7;
            max-width: 260px;
        }

        .footer-col h4 {
            font-size: .9rem;
            font-weight: 700;
            margin-bottom: 16px;
            color: #ccc;
        }

        .footer-col ul {
            list-style: none;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .footer-col ul li a {
            color: #9a9a8a;
            text-decoration: none;
            font-size: .88rem;
        }

        .footer-col ul li a:hover {
            color: #fff;
        }

        .footer-bottom {
            border-top: 1px solid #333;
            padding-top: 24px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            color: #9a9a8a;
            font-size: .82rem;
            max-width: 1300px;
            margin: 0 auto;
        }

        @@media (max-width: 900px) {
            nav {
                padding: 14px 20px;
            }

            .nav-links {
                display: none;
            }

            .footer-top {
                grid-template-columns: 1fr 1fr;
            }
        }
    </style>
</head>
<body>
    <nav>
        <a asp-controller="Home" asp-action="Index" class="nav-logo"><span>E</span>duLink</a>
        <ul class="nav-links">
            <li><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li><a asp-controller="Home" asp-action="Courses">Courses</a></li>
            <li><a asp-controller="Home" asp-action="Blog">Blog</a></li>
            <li><a asp-controller="Home" asp-action="Pages">About</a></li>
            <li><a asp-controller="Home" asp-action="contactus">Contact</a></li>
        </ul>
        <div class="nav-actions">
            <a asp-controller="Home" asp-action="login" class="btn-nav-outline">Log in</a>
            <a asp-controller="Home" asp-action="signup" class="btn-nav-dark">Sign up free</a>
        </div>
    </nav>

    <main role="main">
        @RenderBody()
    </main>

    <footer>
        <div class="footer-top">
            <div class="footer-brand">
                <div class="brand-name"><span>E</span>duLink</div>
                <p>An online learning platform helping thousands of students grow their skills and advance their careers.</p>
            </div>
            <div class="footer-col">
                <h4>Company</h4>
                <ul>
                    <li><a asp-controller="Home" asp-action="Pages">About us</a></li>
                    <li><a href="#">Careers</a></li>
                    <li><a asp-controller="Home" asp-action="Blog">Blog</a></li>
                    <li><a href="#">Press</a></li>
                </ul>
            </div>
            <div class="footer-col">
                <h4>Courses</h4>
                <ul>
                    <li><a asp-controller="Home" asp-action="Courses">IT & Software</a></li>
                    <li><a asp-controller="Home" asp-action="Courses">Design</a></li>
                    <li><a asp-controller="Home" asp-action="Courses">Business</a></li>
                    <li><a asp-controller="Home" asp-action="Courses">Marketing</a></li>
                </ul>
            </div>
            <div class="footer-col">
                <h4>Support</h4>
                <ul>
                    <li><a href="#">Help center</a></li>
                    <li><a asp-controller="Home" asp-action="contactus">Contact us</a></li>
                    <li><a href="#">Privacy policy</a></li>
                    <li><a href="#">Terms of use</a></li>
                </ul>
            </div>
        </div>
        <div class="footer-bottom">
            <span>© @DateTime.Now.Year EduLink. All rights reserved.</span>
            <span>Made with ♥ for learners worldwide</span>
        </div>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
